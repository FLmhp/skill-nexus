{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Skills Nexus",
  "version": "0.1.0",
  "identifier": "com.skillsnexus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skills Nexus",
        "label": "main",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self' https://api.anthropic.com https://api.openai.com http://localhost:*; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          "$HOME/.skills-nexus/**",
          "$HOME/.claude/**",
          "$HOME/.cursor/**",
          "$HOME/.codeium/**",
          "$HOME/.opencode/**",
          "$HOME/.codex/**",
          "$HOME/.continue/**",
          "$HOME/.aider/**",
          "$HOME/.cline/**",
          "$HOME/.github/**",
          "$HOME/.gemini/**",
          "$HOME/.trae/**",
          "$HOME/.roo/**",
          "$HOME/.kilo/**",
          "$HOME/.goose/**",
          "$HOME/.qwen/**"
        ],
        "deny": []
      }
    },
    "shell": {
      "scope": {
        "allow": [
          {
            "name": "git",
            "cmd": "git",
            "args": true
          }
        ],
        "deny": []
      }
    }
  }
}
